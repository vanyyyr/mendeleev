# Supabase connection
DATABASE_URL="postgresql://postgres.[YOUR-SUPABASE-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-SUPABASE-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# OpenRouter (для Qwen-2.5 и др. бесплатных моделей)
OPENROUTER_API_KEY="sk-or-v1-..."

# Analytics dashboard password
ANALYTICS_PASSWORD="your-secure-password"
